
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---------------------------------------------------------------------------
# Microsoft Entra ID (single sign-on) — OPTIONAL
# Leave NEXT_PUBLIC_ENTRA_CLIENT_ID empty to run in the built-in demo sign-in
# mode. Set these (from an Entra app registration) to enable real Microsoft
# work/school-account SSO. These are public, client-side values.
# ---------------------------------------------------------------------------
# Application (client) ID of the Entra app registration
NEXT_PUBLIC_ENTRA_CLIENT_ID=
# Directory (tenant) ID, or "organizations" (any work/school) / "common"
NEXT_PUBLIC_ENTRA_TENANT_ID=organizations
# Redirect URI — defaults to the current origin if left blank
NEXT_PUBLIC_ENTRA_REDIRECT_URI=http://localhost:3000

